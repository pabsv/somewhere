# Flight Scraper — environment template.
# Copy to .env (gitignored) and fill in. The Python backend reads this via python-dotenv.

# MongoDB Atlas connection string (cluster: flightinitialsetup, db: flight_scraper).
# Format: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=

# Optional local-Mongo fallback (ignored when MONGODB_URI is set):
# MONGO_HOST=localhost
# MONGO_PORT=27017
# MONGO_DATABASE=flight_scraper
